# Caddyfile — agentchat reverse proxy with automatic TLS (Let's Encrypt).
#
# Drop this in /etc/caddy/Caddyfile (or wherever your Caddy config lives),
# replace `chat.example.com` with your domain, then `systemctl reload caddy`.
#
# Caddy handles:
#   - TLS cert issuance + renewal (Let's Encrypt)
#   - HTTP/2 + HTTP/3 (QUIC)
#   - SSE-friendly streaming (no buffering)
#   - WebSocket-friendly keepalive

chat.example.com {
    encode zstd gzip

    # Rate-limit auth endpoints (defense in depth — server has its own limiter)
    @auth path /v1/auth/*
    rate_limit @auth 10r/m

    # API
    reverse_proxy 127.0.0.1:7878 {
        # SSE: disable buffering so events stream in real-time
        flush_interval -1
        # Forward real client IP (Caddy populates this by default)
        header_up X-Real-IP {remote_host}
        # Generous timeouts for long-lived SSE connections
        transport http {
            dial_timeout 10s
            response_header_timeout 0   # never timeout headers (streaming)
            read_timeout 0              # never timeout body (SSE)
        }
    }
}

# Optional: redirect www → apex (uncomment if you want)
# www.chat.example.com {
#     redir https://chat.example.com{uri} permanent
# }