# agentchat environment configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# ---- HTTP server ---------------------------------------------------------
# Bind address for the agentchat API.
AGENTCHAT_BIND=0.0.0.0
# Port for the agentchat API (default 7878).
AGENTCHAT_PORT=7878

# ---- Storage -------------------------------------------------------------
# Directory where SQLite DB + identity/token files live.
AGENTCHAT_HOME=/home/waynec/.hermes/agent_chat

# ---- Logging -------------------------------------------------------------
# Set to 1 for verbose request logging.
AGENTCHAT_VERBOSE=0

# ---- Rate limiting (Phase 1+) -------------------------------------------
# Login attempts per minute per IP. 0 = disabled.
LOGIN_RATE_LIMIT=3

# ---- Token policy (Phase 1+) --------------------------------------------
# Access-token lifetime in seconds (default 1h).
TOKEN_TTL_SECONDS=3600
# Refresh-token lifetime in seconds (default 30d).
REFRESH_TTL_SECONDS=2592000
# bcrypt cost factor (10-14; 12 = ~250ms on modern CPU).
BCRYPT_COST=12

# ---- Daemon (Phase 1+) ---------------------------------------------------
# When set, the respond daemon posts replies back via this agent identity.
# Leave blank to skip auto-replies.
AGENTCHAT_RESPOND_AGENT=hermes
# LLM provider + model used by the respond daemon (when implemented).
# LLM_PROVIDER=openai
# LLM_MODEL=claude-sonnet-4-20250514
# OPENAI_API_KEY=sk-replace-me